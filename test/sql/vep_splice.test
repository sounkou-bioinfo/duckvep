# name: test/sql/vep_splice.test
# description: splice precedence + normalized-interval regression cases (match Ensembl VEP).
#   These guard the fixes for the duckvep-specific regressions the error-transition
#   analysis surfaced (see correctness/correctness.md). BRCA1 ENST00000357654 is on
#   the - strand; the intron between exons 43044295-43045802 and 43047643-43047703 is
#   [43045803, 43047642]. Splice is positional, so no FASTA is needed.
# group: [duckvep]

require duckvep

statement ok
SELECT vep_load_cache('test/data/test.gff3', '');

# Deep intron -> just intron_variant.
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43046700, 43046700, 'A', 'G')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
intron_variant

# Essential acceptor (last 2 intronic bases at the - strand 3' end = low genomic end).
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43045803, 43045803, 'A', 'G')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
splice_acceptor_variant

# PRECEDENCE: polypyrimidine tract and splice_region CO-OCCUR (VEP does not suppress
# splice_region with polypyrimidine). The old blanket essential-splice suppression
# wrongly dropped these.
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43045806, 43045806, 'A', 'G')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
intron_variant&splice_polypyrimidine_tract_variant&splice_region_variant

# Essential donor (first 2 intronic bases at the - strand 5' end = high genomic end).
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43047642, 43047642, 'A', 'G')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
splice_donor_variant

# Donor region (3-6 into intron), distinct from the 5th base; co-occurs with intron_variant.
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43047639, 43047639, 'A', 'G')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
intron_variant&splice_donor_region_variant

# NORMALIZED INTERVAL: a deletion's unchanged anchor base must not inflate the
# interval. The 3 bp deletion's trimmed bases sit in the donor -> splice_donor_variant
# (the old anchor-inclusive interval over-reached / mis-classified).
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43047640, 43047642, 'NNN', 'N')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
splice_donor_variant

# INSERTION at the polypyrimidine-tract EDGE. An insertion normalizes to start=end+1
# (here [43045820,43045819]); the reverse-strand PPT window is intron_start+2..+16 =
# [43045805,43045819]. VEP swaps the affected interval to (min,max) before the PPT
# overlap, so an insertion whose lower base touches the window edge IS in the tract.
# Without that swap (the bug that caused 283 insertion under-calls vs VEP) this was
# wrongly dropped to bare intron_variant.
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43045819, 'A', 'AC')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
intron_variant&splice_polypyrimidine_tract_variant

# INSERTION inside both the PPT and the splice_region intronic band -> both terms
# co-occur (VEP _intron_overlap also special-cases insertion boundary touches).
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43045806, 'A', 'AC')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
intron_variant&splice_polypyrimidine_tract_variant&splice_region_variant

# INSERTION just past the PPT window (norm-interval [43045821,43045820]) -> deep intron.
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43045820, 'A', 'AC')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
intron_variant

# INTRON CO-OCCURRENCE (union, not exclusive branch): a deletion spanning the donor
# INTO the intron interior is BOTH the splice terms AND intron_variant. The interval
# [43047639,43047642] reaches the interior (<= intron_end-2 = 43047640), so
# intron_variant co-occurs — the boundary-indel case the union fix added.
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43047638, 43047642, 'NNNNN', 'N')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
intron_variant&splice_donor_region_variant&splice_donor_variant

# Deletion at the acceptor reaching the polypyrimidine interior -> intron_variant +
# polypyrimidine + splice_region all co-occur.
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43045805, 43045807, 'NNN', 'N')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
intron_variant&splice_polypyrimidine_tract_variant&splice_region_variant

# POLYPYRIMIDINE EXON GATE: splice_polypyrimidine_tract_variant is the only splice term
# Ensembl gates on `exon => 0` — a deletion spanning the exon into the PPT interior gets
# splice_acceptor + intron (+ coding) but NOT polypyrimidine, even though the positional
# window matches. (Verified by instrumenting Ensembl VEP.)
query T
SELECT list_aggregate(list_sort(c.consequence),'string_agg','&')
FROM UNNEST(vep_consequence('17', 43045801, 43045810, 'NNNNNNNNNN', 'N')) u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
coding_sequence_variant&intron_variant&splice_acceptor_variant
