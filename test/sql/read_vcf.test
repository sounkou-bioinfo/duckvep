# name: test/sql/read_vcf.test
# description: read_vcf — sites, SV interval (end_pos), multi-sample phased GT
# group: [duckvep]

require duckvep

# Sites: pos, SV-aware end_pos, multiallelic alt list, multi-sample gt list.
query IIII
SELECT pos, end_pos, len(alt), len(gt)
FROM read_vcf('test/data/ms.vcf') ORDER BY pos;
----
1000	1000	1	3
2000	2000	2	3

# Phasing is preserved verbatim in the positional gt list.
query I
SELECT gt[1] FROM read_vcf('test/data/ms.vcf') WHERE pos = 1000;
----
0|1

# SV/CNV: INFO/END drives end_pos so interval filters work.
query II
SELECT pos, end_pos FROM read_vcf('test/data/sv.vcf')
WHERE end_pos - pos > 100 ORDER BY pos;
----
5000	8000
12000	20000

# Symbolic + breakend alleles survive as list elements.
query I
SELECT alt[1] FROM read_vcf('test/data/sv.vcf') WHERE pos = 5000;
----
<DEL>

# Region filter is interval-overlap: matches pos 5000, 9000, 12000.
query I
SELECT count(*) FROM read_vcf('test/data/sv.vcf', region := 'chr1:4000-13000');
----
3

# SVLEN drives end_pos when INFO/END is absent; insertions stay a reference point.
query TII
SELECT id, pos, end_pos FROM read_vcf('test/data/svlen.vcf') ORDER BY pos;
----
del_svlen	5000	5500
ins_svlen	9000	9000
del_end	12000	20000

# Interval overlap + chrom-name normalization: '1' matches a 'chr1' region, and
# a DEL at 5000-5500 is returned by a region fully inside its span.
query I
SELECT id FROM read_vcf('test/data/svlen.vcf', region := 'chr1:5200-5300');
----
del_svlen

# Malformed region bounds are an error, not a silent match-all.
statement error
SELECT count(*) FROM read_vcf('test/data/svlen.vcf', region := 'chr1:1OO-2OO');
----
invalid region
