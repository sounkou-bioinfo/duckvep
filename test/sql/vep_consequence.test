# name: test/sql/vep_consequence.test
# description: scan-driven scalar vep_consequence -> native LIST<STRUCT> (no JSON)
# group: [duckvep]

require duckvep

# Load the engine once into the global cache.
statement ok
SELECT vep_load_cache('test/data/test.gff3', '');

# Native typed LIST<STRUCT>: consequence VARCHAR[], canonical BOOLEAN,
# protein_pos BIGINT. Canonical BRCA1 transcript -> missense (parity).
query TTTI
SELECT c.consequence[1], c.impact, c.canonical, c.protein_pos
FROM UNNEST(vep_consequence('17', 43124090, 'A', 'G')) AS u(c)
WHERE c.transcript_id = 'ENST00000357654';
----
missense_variant	MODERATE	true	3

# Driven by DuckDB's own scan of read_vcf — any source works.
query I
SELECT count(*) > 0
FROM read_vcf('test/data/sites.vcf') v, UNNEST(v.alt) AS a(alt),
     UNNEST(vep_consequence(v.chrom, v.pos, v.ref, a.alt)) AS u(c)
WHERE c.impact = 'MODERATE' AND c.canonical;
----
true

# No-overlap variant returns an empty list, not an error.
query I
SELECT len(vep_consequence('99', 1, 'A', 'G'));
----
0
